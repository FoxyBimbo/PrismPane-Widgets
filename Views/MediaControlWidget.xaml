<Window x:Class="EchoUI.Views.MediaControlWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Media Control" Width="320" Height="44"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="False"
        ShowInTaskbar="False" ResizeMode="NoResize"
        ShowActivated="False">
    <Border x:Name="RootBorder"
            Background="{DynamicResource WindowBackgroundSemiBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="8,4">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Settings" Click="MenuSettings_Click"/>
                <MenuItem Header="Close" Click="MenuClose_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock x:Name="TxtTitle"
                           Text="No media playing"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="TxtStatus"
                           Text="Waiting for an active media session"
                           FontSize="11"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnPrevious"
                        Content="⏮"
                        Width="28"
                        Height="28"
                        Margin="0,0,4,0"
                        Click="BtnPrevious_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource ForegroundBrush}"
                        BorderBrush="Transparent"
                        FontSize="15"
                        Cursor="Hand"
                        ToolTip="Rewind"/>
                <Button x:Name="BtnPlayPause"
                        Content="▶"
                        Width="28"
                        Height="28"
                        Margin="0,0,4,0"
                        Click="BtnPlayPause_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource ForegroundBrush}"
                        BorderBrush="Transparent"
                        FontSize="15"
                        Cursor="Hand"
                        ToolTip="Play"/>
                <Button x:Name="BtnNext"
                        Content="⏭"
                        Width="28"
                        Height="28"
                        Click="BtnNext_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource ForegroundBrush}"
                        BorderBrush="Transparent"
                        FontSize="15"
                        Cursor="Hand"
                        ToolTip="Skip"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
